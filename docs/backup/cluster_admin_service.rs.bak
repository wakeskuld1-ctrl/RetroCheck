use crate::pb::cluster_admin_server::ClusterAdmin;
use crate::pb::{AddHubRequest, AddHubResponse, NodeCompatibility, RemoveHubRequest, RemoveHubResponse};
use crate::management::cluster_admin_domain::{
    AddHubError, CompatibilityChecker, StrictCompatibilityChecker, TopologyService,
    add_hub_error_response, default_compatibility as domain_default_compatibility,
    global_topology_service, normalize_grpc_addr, not_leader_response, remove_hub_not_leader_response,
    remove_hub_response,
};
use crate::raft::network::RaftRouter;
use crate::raft::raft_node::RaftNode;
use anyhow::{Result, anyhow};
use openraft::{BasicNode, ServerState};
use std::collections::{BTreeSet, HashMap, VecDeque};
use std::sync::Arc;
use std::time::{Duration, SystemTime, UNIX_EPOCH};
use tokio::sync::Mutex;
use tonic::{Request, Response, Status};
use uuid::Uuid;

pub use crate::management::cluster_admin_domain::ClusterBaseline;

const AUDIT_EVENT_LIMIT: usize = 256;

pub trait DrainSignal: Send + Sync {
    fn set_reject_new(&self, reject_new: bool);
    fn inflight_requests(&self) -> u64;
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub struct ClusterAuditEvent {
    pub action: String,
    pub status: String,
    pub detail: String,
    pub timestamp_ms: u64,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub struct AddEdgeRequest {
    pub edge_id: String,
    pub group_id: Option<String>,
    pub request_id: String,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub struct AddEdgeResponse {
    pub ready: bool,
    pub reason_code: String,
    pub suggested_action: String,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub struct EdgeMetadataError {
    pub reason_code: String,
    pub message: String,
}

impl EdgeMetadataError {
    pub fn target_metadata_missing(message: String) -> Self {
        Self {
            reason_code: "TARGET_METADATA_MISSING".to_string(),
            message,
        }
    }

    pub fn target_not_found(message: String) -> Self {
        Self {
            reason_code: "TARGET_NOT_FOUND".to_string(),
            message,
        }
    }
}

#[tonic::async_trait]
pub trait EdgeMetadataProvider: Send + Sync {
    async fn pull_group_metadata(&self, group_id: &str) -> std::result::Result<(), EdgeMetadataError>;
}

#[tonic::async_trait]
pub trait AddEdgeForwardTarget: Send + Sync {
    async fn handle_forwarded_add_edge(&self, req: AddEdgeRequest) -> AddEdgeResponse;
}

struct NoopEdgeMetadataProvider;

#[tonic::async_trait]
impl EdgeMetadataProvider for NoopEdgeMetadataProvider {
    async fn pull_group_metadata(
        &self,
        _group_id: &str,
    ) -> std::result::Result<(), EdgeMetadataError> {
        Ok(())
    }
}

#[derive(Debug, Clone, PartialEq, Eq)]
struct RegisteredEdge {
    edge_id: String,
    group_id: Option<String>,
    ready: bool,
}

struct ClusterState {
    nodes: HashMap<u64, Arc<RaftNode>>,
    voters: BTreeSet<u64>,
    add_request_cache: HashMap<String, AddHubResponse>,
    add_edge_request_cache: HashMap<String, AddEdgeResponse>,
    edge_forward_targets: HashMap<String, Arc<dyn AddEdgeForwardTarget>>,
    remove_request_cache: HashMap<String, RemoveHubResponse>,
    edges: HashMap<String, RegisteredEdge>,
    draining_nodes: HashMap<u64, u64>,
    drain_signals: HashMap<u64, Arc<dyn DrainSignal>>,
    membership_version: u64,
    bootstrapped: bool,
    audit_events: VecDeque<ClusterAuditEvent>,
}

impl ClusterState {
    fn new(local_node_id: u64, local_node: Arc<RaftNode>) -> Self {
        let mut nodes = HashMap::new();
        nodes.insert(local_node_id, local_node);
        let mut voters = BTreeSet::new();
        voters.insert(local_node_id);
        Self {
            nodes,
            voters,
            add_request_cache: HashMap::new(),
            add_edge_request_cache: HashMap::new(),
            edge_forward_targets: HashMap::new(),
            remove_request_cache: HashMap::new(),
            edges: HashMap::new(),
            draining_nodes: HashMap::new(),
            drain_signals: HashMap::new(),
            membership_version: 1,
            bootstrapped: false,
            audit_events: VecDeque::new(),
        }
    }
}

#[derive(Clone)]
pub struct ClusterNodeManager {
    local_node_id: u64,
    leader_node: Arc<RaftNode>,
    raft_router: RaftRouter,
    compatibility_checker: Arc<dyn CompatibilityChecker>,
    edge_metadata_provider: Arc<dyn EdgeMetadataProvider>,
    topology_service: Arc<dyn TopologyService>,
    state: Arc<Mutex<ClusterState>>,
}

impl ClusterNodeManager {
    fn now_ms() -> u64 {
        SystemTime::now()
            .duration_since(UNIX_EPOCH)
            .map(|d| d.as_millis() as u64)
            .unwrap_or(0)
    }

    fn push_audit_event(
        state: &mut ClusterState,
        action: &str,
        status: &str,
        detail: impl Into<String>,
    ) {
        if state.audit_events.len() >= AUDIT_EVENT_LIMIT {
            state.audit_events.pop_front();
        }
        state.audit_events.push_back(ClusterAuditEvent {
            action: action.to_string(),
            status: status.to_string(),
            detail: detail.into(),
            timestamp_ms: Self::now_ms(),
        });
    }

    async fn append_audit_event(&self, action: &str, status: &str, detail: impl Into<String>) {
        let mut state = self.state.lock().await;
        Self::push_audit_event(&mut state, action, status, detail);
    }

    pub fn new(
        local_node_id: u64,
        local_grpc_addr: String,
        leader_node: Arc<RaftNode>,
        raft_router: RaftRouter,
        baseline: ClusterBaseline,
    ) -> Self {
        let compatibility_checker = Arc::new(StrictCompatibilityChecker::new(baseline));
        let topology_service = global_topology_service();
        Self::new_with_services(
            local_node_id,
            local_grpc_addr,
            leader_node,
            raft_router,
            compatibility_checker,
            topology_service,
        )
    }

    pub fn new_with_topology(
        local_node_id: u64,
        local_grpc_addr: String,
        leader_node: Arc<RaftNode>,
        raft_router: RaftRouter,
        baseline: ClusterBaseline,
        topology_service: Arc<dyn TopologyService>,
    ) -> Self {
        let compatibility_checker = Arc::new(StrictCompatibilityChecker::new(baseline));
        Self::new_with_services(
            local_node_id,
            local_grpc_addr,
            leader_node,
            raft_router,
            compatibility_checker,
            topology_service,
        )
    }

    pub fn new_with_checker(
        local_node_id: u64,
        local_grpc_addr: String,
        leader_node: Arc<RaftNode>,
        raft_router: RaftRouter,
        compatibility_checker: Arc<dyn CompatibilityChecker>,
    ) -> Self {
        let topology_service = global_topology_service();
        Self::new_with_services(
            local_node_id,
            local_grpc_addr,
            leader_node,
            raft_router,
            compatibility_checker,
            topology_service,
        )
    }

    pub fn new_with_services(
        local_node_id: u64,
        local_grpc_addr: String,
        leader_node: Arc<RaftNode>,
        raft_router: RaftRouter,
        compatibility_checker: Arc<dyn CompatibilityChecker>,
        topology_service: Arc<dyn TopologyService>,
    ) -> Self {
        Self::new_with_services_and_edge_metadata(
            local_node_id,
            local_grpc_addr,
            leader_node,
            raft_router,
            compatibility_checker,
            topology_service,
            Arc::new(NoopEdgeMetadataProvider),
        )
    }

    pub fn new_with_services_and_edge_metadata(
        local_node_id: u64,
        local_grpc_addr: String,
        leader_node: Arc<RaftNode>,
        raft_router: RaftRouter,
        compatibility_checker: Arc<dyn CompatibilityChecker>,
        topology_service: Arc<dyn TopologyService>,
        edge_metadata_provider: Arc<dyn EdgeMetadataProvider>,
    ) -> Self {
        topology_service.upsert_grpc_addr(local_node_id, local_grpc_addr);
        let state = ClusterState::new(local_node_id, leader_node.clone());
        Self {
            local_node_id,
            leader_node,
            raft_router,
            compatibility_checker,
            edge_metadata_provider,
            topology_service,
            state: Arc::new(Mutex::new(state)),
        }
    }

    pub async fn bootstrap_local_if_needed(&self) -> Result<()> {
        self.ensure_bootstrapped().await
    }

    async fn ensure_bootstrapped(&self) -> Result<()> {
        {
            let state = self.state.lock().await;
            if state.bootstrapped {
                return Ok(());
            }
        }

        let current_leader = self.current_leader_id().await?;
        if current_leader == Some(self.local_node_id) {
            let mut state = self.state.lock().await;
            state.bootstrapped = true;
            Self::push_audit_event(&mut state, "cluster.bootstrap", "ok", "local node is leader");
            return Ok(());
        }

        let mut members = BTreeSet::new();
        members.insert(self.local_node_id);
        match self.leader_node.raft.initialize(members).await {
            Ok(_) => {}
            Err(err) => {
                let msg = err.to_string();
                if !msg.contains("already initialized") {
                    self.append_audit_event("cluster.bootstrap", "err", msg.clone())
                        .await;
                    return Err(anyhow!(msg));
                }
            }
        }

        self.wait_for_leader().await?;
        let mut state = self.state.lock().await;
        state.bootstrapped = true;
        Self::push_audit_event(
            &mut state,
            "cluster.bootstrap",
            "ok",
            "cluster initialized and leader elected",
        );
        Ok(())
    }

    async fn wait_for_leader(&self) -> Result<u64> {
        for _ in 0..100 {
            if let Some(leader_id) = self.current_leader_id().await? {
                return Ok(leader_id);
            }
            tokio::time::sleep(Duration::from_millis(100)).await;
        }
        Err(anyhow!("leader not elected"))
    }

    async fn current_leader_id(&self) -> Result<Option<u64>> {
        let nodes = {
            let state = self.state.lock().await;
            state.nodes.values().cloned().collect::<Vec<_>>()
        };

        for node in nodes {
            let metrics = node.raft.metrics().borrow().clone();
            if metrics.state == ServerState::Leader
                && matches!(metrics.current_leader, Some(id) if id == node.node_id())
            {
                return Ok(Some(node.node_id()));
            }
        }
        Ok(None)
    }

    async fn ensure_leader_or_redirect(&self) -> Result<Option<String>> {
        let leader_id = self.wait_for_leader().await?;
        if leader_id == self.local_node_id {
            return Ok(None);
        }
        let leader_hint = self.resolve_leader_hint(leader_id).await;
        self.append_audit_event(
            "cluster.redirect",
            "ok",
            format!("leader_id={},leader_hint={}", leader_id, leader_hint),
        )
        .await;
        Ok(Some(leader_hint))
    }

    async fn precheck_add(
        &self,
        req: &AddHubRequest,
    ) -> std::result::Result<Option<AddHubResponse>, AddHubError> {
        if req.node_id == 0 {
            return Err(AddHubError::invalid_argument(
                "node_id must be > 0",
                "set node_id to a non-zero unique value",
            ));
        }
        if req.request_id.trim().is_empty() {
            return Err(AddHubError::invalid_argument(
                "request_id is required",
                "set request_id to a stable idempotency key",
            ));
        }
        if req.raft_addr.trim().is_empty() {
            return Err(AddHubError::invalid_argument(
                "raft_addr is required",
                "set raft_addr to a reachable raft endpoint",
            ));
        }
        if req.grpc_addr.trim().is_empty() {
            return Err(AddHubError::invalid_argument(
                "grpc_addr is required",
                "set grpc_addr to a reachable grpc endpoint",
            ));
        }

        let state = self.state.lock().await;
        if let Some(cached) = state.add_request_cache.get(&req.request_id) {
            return Ok(Some(cached.clone()));
        }
        if state.nodes.contains_key(&req.node_id) {
            return Err(AddHubError::already_exists(
                "node_id already exists",
                "use a different node_id or retry with original request_id",
            ));
        }
        Ok(None)
    }

    async fn resolve_leader_hint(&self, leader_id: u64) -> String {
        self.topology_service
            .get_grpc_addr(leader_id)
            .unwrap_or_else(|| format!("node://{}", leader_id))
    }

    async fn set_reject_new_if_available(&self, node_id: u64, reject_new: bool) {
        let signal = {
            let state = self.state.lock().await;
            state.drain_signals.get(&node_id).cloned()
        };
        if let Some(signal) = signal {
            signal.set_reject_new(reject_new);
        }
    }

    async fn wait_for_inflight_zero(&self, node_id: u64, timeout_ms: u64) -> Result<()> {
        let signal = {
            let state = self.state.lock().await;
            state.drain_signals.get(&node_id).cloned()
        };
        let Some(signal) = signal else {
            return Ok(());
        };
        let deadline = tokio::time::Instant::now() + Duration::from_millis(timeout_ms.max(1));
        loop {
            if signal.inflight_requests() == 0 {
                return Ok(());
            }
            if tokio::time::Instant::now() >= deadline {
                return Err(anyhow!("drain timeout"));
            }
            tokio::time::sleep(Duration::from_millis(20)).await;
        }
    }

    async fn transfer_leader_and_wait(&self, leaving_node_id: u64, timeout_ms: u64) -> Result<u64> {
        let candidates = {
            let state = self.state.lock().await;
            state
                .voters
                .iter()
                .filter(|id| **id != leaving_node_id)
                .filter_map(|id| state.nodes.get(id).cloned())
                .collect::<Vec<_>>()
        };
        if candidates.is_empty() {
            return Err(anyhow!("no voter candidate for leader transfer"));
        }
        for node in &candidates {
            let _ = node.raft.trigger().elect().await;
        }
        let deadline = tokio::time::Instant::now() + Duration::from_millis(timeout_ms.max(1));
        loop {
            if let Some(leader_id) = self.current_leader_id().await?
                && leader_id != leaving_node_id
            {
                return Ok(leader_id);
            }
            if tokio::time::Instant::now() >= deadline {
                return Err(anyhow!("leader transfer timeout"));
            }
            tokio::time::sleep(Duration::from_millis(50)).await;
        }
    }

    async fn leader_node_for_membership_change(&self) -> Result<Arc<RaftNode>> {
        let leader_id = self.wait_for_leader().await?;
        let state = self.state.lock().await;
        state
            .nodes
            .get(&leader_id)
            .cloned()
            .ok_or_else(|| anyhow!("leader node handle not found"))
    }

    pub async fn add_hub(
        &self,
        req: AddHubRequest,
    ) -> std::result::Result<AddHubResponse, AddHubError> {
        if let Err(e) = self.ensure_bootstrapped().await {
            let detail = format!("cluster bootstrap failed: {}", e);
            self.append_audit_event("cluster.add_hub", "err", detail.clone())
                .await;
            return Err(AddHubError::invalid_argument(
                detail,
                "verify local node state and raft bootstrap condition",
            ));
        }

        if let Some(existing) = self.precheck_add(&req).await? {
            return Ok(existing);
        }
        self.compatibility_checker.check(&req)?;

        let node_base_dir =
            std::env::temp_dir().join(format!("hub_dynamic_node_{}_{}", req.node_id, Uuid::new_v4()));
        let node = RaftNode::start(req.node_id, node_base_dir, self.raft_router.clone())
            .await
            .map_err(|e| {
                AddHubError::invalid_argument(
                    format!("failed to start node: {}", e),
                    "check node runtime and storage path permissions",
                )
            })?;
        self.raft_router.register(req.node_id, Arc::new(node.clone()));

        self.leader_node
            .raft
            .add_learner(req.node_id, BasicNode::new(req.raft_addr.clone()), true)
            .await
            .map_err(|e| {
                AddHubError::invalid_argument(
                    format!("add_learner failed: {}", e),
                    "verify raft_addr reachability and node_id uniqueness in raft membership",
                )
            })?;

        let promote_voters = if req.auto_promote {
            let mut voters = {
                let state = self.state.lock().await;
                state.voters.clone()
            };
            voters.insert(req.node_id);
            Some(voters)
        } else {
            None
        };

        if let Some(voters) = promote_voters.clone() {
            self.leader_node
                .raft
                .change_membership(voters, true)
                .await
                .map_err(|e| {
                    AddHubError::invalid_argument(
                        format!("change_membership failed: {}", e),
                        "retry after cluster stabilizes or set auto_promote=false first",
                    )
                })?;
        }

        let mut state = self.state.lock().await;
        state.nodes.insert(req.node_id, Arc::new(node));
        self.topology_service
            .upsert_grpc_addr(req.node_id, req.grpc_addr);
        if let Some(voters) = promote_voters {
            state.voters = voters;
        }
        state.membership_version = state.membership_version.saturating_add(1);
        if req.auto_promote {
            state.membership_version = state.membership_version.saturating_add(1);
        }
        let resp = AddHubResponse {
            membership_version: state.membership_version,
            leader_hint: String::new(),
            reason_code: String::new(),
            suggested_action: String::new(),
        };
        state.add_request_cache.insert(req.request_id, resp.clone());
        Self::push_audit_event(
            &mut state,
            "cluster.add_hub",
            "ok",
            format!("node_id={},auto_promote={}", req.node_id, req.auto_promote),
        );
        Ok(resp)
    }

    pub async fn remove_hub(&self, req: RemoveHubRequest) -> Result<RemoveHubResponse> {
        if req.node_id == 0 {
            return Ok(remove_hub_response(
                0,
                "INVALID_ARGUMENT",
                "set node_id to a non-zero unique value",
                "INVALID",
            ));
        }
        if req.request_id.trim().is_empty() {
            return Ok(remove_hub_response(
                0,
                "INVALID_ARGUMENT",
                "set request_id to a stable idempotency key",
                "INVALID",
            ));
        }
        let phase = req.phase.trim().to_ascii_uppercase();
        if phase != "MARK_DRAINING" && phase != "COMMIT" {
            return Ok(remove_hub_response(
                0,
                "INVALID_PHASE",
                "phase must be MARK_DRAINING or COMMIT",
                "INVALID",
            ));
        }
        if let Err(err) = self.ensure_bootstrapped().await {
            let detail = format!("cluster bootstrap failed: {}", err);
            self.append_audit_event("cluster.remove_hub", "err", detail).await;
            return Ok(remove_hub_response(
                0,
                "BOOTSTRAP_FAILED",
                "verify local node state and raft bootstrap condition",
                "INVALID",
            ));
        }

        if phase == "MARK_DRAINING" {
            let mut state = self.state.lock().await;
            if let Some(cached) = state.remove_request_cache.get(&req.request_id) {
                return Ok(cached.clone());
            }
            if !state.nodes.contains_key(&req.node_id) {
                let resp = remove_hub_response(
                    0,
                    "NODE_NOT_FOUND",
                    "verify node_id and cluster topology",
                    "UNKNOWN",
                );
                state
                    .remove_request_cache
                    .insert(req.request_id.clone(), resp.clone());
                Self::push_audit_event(
                    &mut state,
                    "cluster.remove_hub.mark",
                    "err",
                    format!("node_id={} not found", req.node_id),
                );
                return Ok(resp);
            }
            state.draining_nodes.insert(req.node_id, Self::now_ms());
            let resp = remove_hub_response(
                state.membership_version,
                "DRAINING_MARKED",
                "commit removal when in-flight requests are drained",
                "DRAINING",
            );
            state
                .remove_request_cache
                .insert(req.request_id.clone(), resp.clone());
            Self::push_audit_event(
                &mut state,
                "cluster.remove_hub.mark",
                "ok",
                format!("node_id={}", req.node_id),
            );
            drop(state);
            self.set_reject_new_if_available(req.node_id, true).await;
            return Ok(resp);
        }

        let (target_node, new_voters, membership_version_before, need_transfer_leader) = {
            let mut state = self.state.lock().await;
            if let Some(cached) = state.remove_request_cache.get(&req.request_id) {
                return Ok(cached.clone());
            }
            if !state.nodes.contains_key(&req.node_id) {
                let resp = remove_hub_response(
                    0,
                    "NODE_NOT_FOUND",
                    "verify node_id and cluster topology",
                    "UNKNOWN",
                );
                state
                    .remove_request_cache
                    .insert(req.request_id.clone(), resp.clone());
                Self::push_audit_event(
                    &mut state,
                    "cluster.remove_hub.commit",
                    "err",
                    format!("node_id={} not found", req.node_id),
                );
                return Ok(resp);
            }
            if !state.draining_nodes.contains_key(&req.node_id) {
                let resp = remove_hub_response(
                    state.membership_version,
                    "NOT_DRAINING",
                    "mark node as draining before commit",
                    "ACTIVE",
                );
                state
                    .remove_request_cache
                    .insert(req.request_id.clone(), resp.clone());
                Self::push_audit_event(
                    &mut state,
                    "cluster.remove_hub.commit",
                    "err",
                    format!("node_id={} not draining", req.node_id),
                );
                return Ok(resp);
            }
            let need_transfer_leader = req.node_id == self.local_node_id && !req.force;
            let target_node = state.nodes.get(&req.node_id).cloned();
            let new_voters = if state.voters.contains(&req.node_id) {
                let mut voters = state.voters.clone();
                voters.remove(&req.node_id);
                Some(voters)
            } else {
                None
            };
            (
                target_node,
                new_voters,
                state.membership_version,
                need_transfer_leader,
            )
        };

        if need_transfer_leader
            && self
                .transfer_leader_and_wait(req.node_id, req.drain_timeout_ms)
                .await
                .is_err()
        {
            let mut state = self.state.lock().await;
            let resp = remove_hub_response(
                membership_version_before,
                "LEADER_TRANSFER_TIMEOUT",
                "retry commit after cluster stabilizes or use force=true in emergency",
                "DRAINING",
            );
            state
                .remove_request_cache
                .insert(req.request_id.clone(), resp.clone());
            Self::push_audit_event(
                &mut state,
                "cluster.remove_hub.commit",
                "err",
                format!("leader transfer timeout for node_id={}", req.node_id),
            );
            return Ok(resp);
        }

        if self
            .wait_for_inflight_zero(req.node_id, req.drain_timeout_ms)
            .await
            .is_err()
        {
            let mut state = self.state.lock().await;
            let resp = remove_hub_response(
                membership_version_before,
                "DRAIN_TIMEOUT",
                "wait for in-flight requests to drain and retry commit",
                "DRAINING",
            );
            state
                .remove_request_cache
                .insert(req.request_id.clone(), resp.clone());
            Self::push_audit_event(
                &mut state,
                "cluster.remove_hub.commit",
                "err",
                format!("drain timeout for node_id={}", req.node_id),
            );
            return Ok(resp);
        }

        if let Some(voters) = new_voters {
            if voters.is_empty() && !req.force {
                return Ok(remove_hub_response(
                    membership_version_before,
                    "LAST_VOTER_FORBIDDEN",
                    "at least one voter is required unless force=true",
                    "DRAINING",
                ));
            }
            self.leader_node_for_membership_change()
                .await?
                .raft
                .change_membership(voters, false)
                .await
                .map_err(|e| anyhow!("change_membership failed: {}", e))?;
        }

        if let Some(node) = target_node {
            let _ = node.shutdown().await;
        }
        self.raft_router.unregister(req.node_id);
        self.topology_service.remove_grpc_addr(req.node_id);

        let mut state = self.state.lock().await;
        state.nodes.remove(&req.node_id);
        state.voters.remove(&req.node_id);
        state.draining_nodes.remove(&req.node_id);
        state.membership_version = state.membership_version.saturating_add(1);
        let resp = remove_hub_response(state.membership_version, "", "", "REMOVED");
        state
            .remove_request_cache
            .insert(req.request_id.clone(), resp.clone());
        Self::push_audit_event(
            &mut state,
            "cluster.remove_hub.commit",
            "ok",
            format!("node_id={}", req.node_id),
        );
        Ok(resp)
    }

    pub async fn add_edge(&self, req: AddEdgeRequest) -> AddEdgeResponse {
        let leader_hint = match self.current_leader_id().await {
            Ok(Some(leader_id)) if leader_id != self.local_node_id => {
                Some(self.resolve_leader_hint(leader_id).await)
            }
            _ => None,
        };
        if let Some(leader_hint) = leader_hint {
            if let Some(resp) = self
                .forward_add_edge_to_target(&leader_hint, req.clone())
                .await
            {
                return resp;
            }
            return AddEdgeResponse {
                ready: false,
                reason_code: "NOT_LEADER".to_string(),
                suggested_action: format!("retry request to {}", leader_hint),
            };
        }
        self.add_edge_local(req).await
    }

    async fn forward_add_edge_to_target(
        &self,
        leader_hint: &str,
        req: AddEdgeRequest,
    ) -> Option<AddEdgeResponse> {
        let normalized_hint = normalize_grpc_addr(leader_hint.to_string());
        let target = {
            let state = self.state.lock().await;
            state.edge_forward_targets.get(&normalized_hint).cloned()
        };
        if let Some(target) = target {
            let resp = target.handle_forwarded_add_edge(req).await;
            self.append_audit_event(
                "cluster.add_edge.forward",
                "ok",
                format!(
                    "leader_hint={},reason_code={}",
                    normalized_hint,
                    if resp.reason_code.is_empty() {
                        "OK"
                    } else {
                        &resp.reason_code
                    }
                ),
            )
            .await;
            return Some(resp);
        }
        self.append_audit_event(
            "cluster.add_edge.forward",
            "err",
            format!("leader_hint={},reason_code=FORWARD_TARGET_MISSING", normalized_hint),
        )
        .await;
        None
    }

    async fn add_edge_local(&self, req: AddEdgeRequest) -> AddEdgeResponse {
        if req.edge_id.trim().is_empty() {
            return AddEdgeResponse {
                ready: false,
                reason_code: "INVALID_ARGUMENT".to_string(),
                suggested_action: "set edge_id to a non-empty unique value".to_string(),
            };
        }
        if req.request_id.trim().is_empty() {
            return AddEdgeResponse {
                ready: false,
                reason_code: "INVALID_ARGUMENT".to_string(),
                suggested_action: "set request_id to a stable idempotency key".to_string(),
            };
        }

        {
            let state = self.state.lock().await;
            if let Some(cached) = state.add_edge_request_cache.get(&req.request_id) {
                return cached.clone();
            }
            if state.edges.contains_key(&req.edge_id) {
                return AddEdgeResponse {
                    ready: false,
                    reason_code: "ALREADY_EXISTS".to_string(),
                    suggested_action: "use a different edge_id or retry with original request_id"
                        .to_string(),
                };
            }
        }

        let maybe_group_id = req
            .group_id
            .as_ref()
            .map(|group_id| group_id.trim().to_string())
            .filter(|group_id| !group_id.is_empty());

        if let Some(group_id) = maybe_group_id.clone() {
            match self.edge_metadata_provider.pull_group_metadata(&group_id).await {
                Ok(()) => {
                    self.append_audit_event(
                        "cluster.add_edge.group_metadata_pull",
                        "ok",
                        format!("edge_id={},group_id={}", req.edge_id, group_id),
                    )
                    .await;
                }
                Err(err) => {
                    self.append_audit_event(
                        "cluster.add_edge.group_metadata_pull",
                        "err",
                        format!(
                            "edge_id={},group_id={},reason_code={}",
                            req.edge_id, group_id, err.reason_code
                        ),
                    )
                    .await;
                    let resp = AddEdgeResponse {
                        ready: false,
                        reason_code: err.reason_code,
                        suggested_action: err.message,
                    };
                    let mut state = self.state.lock().await;
                    state
                        .add_edge_request_cache
                        .insert(req.request_id.clone(), resp.clone());
                    return resp;
                }
            }
        }

        let mut state = self.state.lock().await;
        state.edges.insert(
            req.edge_id.clone(),
            RegisteredEdge {
                edge_id: req.edge_id.clone(),
                group_id: maybe_group_id,
                ready: true,
            },
        );
        let resp = AddEdgeResponse {
            ready: true,
            reason_code: String::new(),
            suggested_action: String::new(),
        };
        state
            .add_edge_request_cache
            .insert(req.request_id.clone(), resp.clone());
        Self::push_audit_event(
            &mut state,
            "cluster.add_edge.ready",
            "ok",
            format!("edge_id={}", req.edge_id),
        );
        resp
    }

    pub async fn register_edge_forward_target(
        &self,
        grpc_addr: String,
        target: Arc<dyn AddEdgeForwardTarget>,
    ) {
        let mut state = self.state.lock().await;
        state
            .edge_forward_targets
            .insert(normalize_grpc_addr(grpc_addr), target);
    }

    pub async fn node_count(&self) -> usize {
        let state = self.state.lock().await;
        state.nodes.len()
    }

    pub async fn register_known_grpc_addr(&self, node_id: u64, grpc_addr: String) {
        self.topology_service.upsert_grpc_addr(node_id, grpc_addr);
    }

    pub async fn audit_events_snapshot(&self) -> Vec<ClusterAuditEvent> {
        let state = self.state.lock().await;
        state.audit_events.iter().cloned().collect()
    }

    pub async fn register_drain_signal(&self, node_id: u64, signal: Arc<dyn DrainSignal>) {
        let mut state = self.state.lock().await;
        state.drain_signals.insert(node_id, signal);
    }
}

#[tonic::async_trait]
impl AddEdgeForwardTarget for ClusterNodeManager {
    async fn handle_forwarded_add_edge(&self, req: AddEdgeRequest) -> AddEdgeResponse {
        self.add_edge_local(req).await
    }
}

#[derive(Clone)]
pub struct ClusterAdminService {
    manager: Arc<ClusterNodeManager>,
}

impl ClusterAdminService {
    pub fn new(manager: Arc<ClusterNodeManager>) -> Self {
        Self { manager }
    }
}

#[tonic::async_trait]
impl ClusterAdmin for ClusterAdminService {
    async fn add_hub(
        &self,
        request: Request<AddHubRequest>,
    ) -> Result<Response<AddHubResponse>, Status> {
        if let Some(leader_hint) = self
            .manager
            .ensure_leader_or_redirect()
            .await
            .map_err(|e| Status::unavailable(e.to_string()))?
        {
            return Ok(Response::new(not_leader_response(leader_hint)));
        }

        let req = request.into_inner();
        let resp = match self.manager.add_hub(req).await {
            Ok(resp) => resp,
            Err(err) => return Ok(Response::new(add_hub_error_response(err))),
        };
        Ok(Response::new(resp))
    }

    async fn remove_hub(
        &self,
        request: Request<RemoveHubRequest>,
    ) -> Result<Response<RemoveHubResponse>, Status> {
        if let Some(leader_hint) = self
            .manager
            .ensure_leader_or_redirect()
            .await
            .map_err(|e| Status::unavailable(e.to_string()))?
        {
            return Ok(Response::new(remove_hub_not_leader_response(leader_hint)));
        }
        let req = request.into_inner();
        let resp = self
            .manager
            .remove_hub(req)
            .await
            .map_err(|e| Status::internal(e.to_string()))?;
        Ok(Response::new(resp))
    }
}

pub fn default_compatibility(app_semver: String) -> NodeCompatibility {
    domain_default_compatibility(app_semver)
}
